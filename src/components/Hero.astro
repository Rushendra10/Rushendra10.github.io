---
import NewsRail from "./NewsRail.astro";
import { profile } from "../data/profile";

const emailAddress = profile.links.email.replace("mailto:", "");

const quickLinks = [
  { label: "Resume", href: profile.links.resume, icon: "PDF", tone: "document", width: "half" },
  { label: "CV", href: profile.links.cv, icon: "CV", tone: "document", width: "half" },
  { label: emailAddress, href: profile.links.email, icon: "@", tone: "email", width: "full" },
  { label: "LinkedIn", href: profile.links.linkedin, icon: "in", tone: "linkedin", width: "third" },
  { label: "Scholar", href: profile.links.scholar, icon: "G", tone: "scholar", width: "third" },
  { label: "GitHub", href: profile.links.github, icon: "GH", tone: "github", width: "third" },
];
---

<section class="hero container" aria-labelledby="hero-title">
  <div class="hero__grid">
    <div>
      <p class="eyebrow">{profile.affiliation}</p>
      <h1 id="hero-title">{profile.name}</h1>
      <p class="hero__lead">{profile.summary}</p>

      <div class="hero__status">
        <span class="hero__status-dot" aria-hidden="true"></span>
        <span>{profile.availability}</span>
      </div>
    </div>

    <div class="hero__card">
      <div class="portrait-card">
        <div class="portrait-card__image">
          <img src={profile.photo} alt={`Portrait of ${profile.name}`} loading="eager" />
        </div>
      </div>

      <div class="quick-links" aria-label="Profile links">
        {
          quickLinks.map((item) => (
            <a
              class:list={[
                "quick-link",
                `quick-link--${item.width}`,
                `quick-link--${item.tone}`,
              ]}
              href={item.href}
              target={item.href.startsWith("mailto:") ? undefined : "_blank"}
              rel={item.href.startsWith("mailto:") ? undefined : "noreferrer"}
            >
              <span class:list={["quick-link__icon", `quick-link__icon--${item.tone}`]} aria-hidden="true">
                {item.icon}
              </span>
              <span class="quick-link__label">{item.label}</span>
            </a>
          ))
        }
      </div>

      <NewsRail />
    </div>
  </div>
</section>

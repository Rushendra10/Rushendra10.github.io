---
import { publications } from "../data/publications";
---

<section class="section compact-section" id="publications" aria-labelledby="publications-title">
  <div class="container">
    <div class="compact-heading">
      <h2 id="publications-title">Research Outputs</h2>
      <span aria-hidden="true"></span>
    </div>

    <div class="research-carousel">
      <div class="research-track" data-research-track tabindex="0" aria-label="Research outputs">
      {
        publications.map((publication, index) => (
          <article class:list={["research-card", index === 0 && "research-card--active"]} data-research-card>
            <div class="research-card__top">
              <span class="research-card__year">{publication.year}</span>
              <p class="research-card__venue">{publication.venue}</p>
            </div>

            <div class="research-card__body">
              <h3>{publication.title}</h3>
              <p>{publication.summary}</p>
            </div>

            <p class="research-card__authors">{publication.authors}</p>

            <ul class="compact-links research-card__links" aria-label={`${publication.title} links`}>
              {
                publication.links.map((link) => (
                  <li>
                    <a href={link.href} target="_blank" rel="noreferrer">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
      </div>
    </div>
  </div>
</section>

<script>
  const researchTracks = document.querySelectorAll("[data-research-track]");

  researchTracks.forEach((track) => {
    if (!(track instanceof HTMLElement)) {
      return;
    }

    const cards = Array.from(track.querySelectorAll("[data-research-card]")).filter(
      (card): card is HTMLElement => card instanceof HTMLElement,
    );

    let pendingFrame = 0;

    const updateFocusedCard = () => {
      pendingFrame = 0;

      const trackCenter = track.scrollLeft + track.clientWidth / 2;
      let focusedCard: HTMLElement | null = null;
      let shortestDistance = Number.POSITIVE_INFINITY;

      cards.forEach((card) => {
        const cardCenter = card.offsetLeft + card.offsetWidth / 2;
        const distance = Math.abs(cardCenter - trackCenter);

        if (distance < shortestDistance) {
          shortestDistance = distance;
          focusedCard = card;
        }
      });

      cards.forEach((card) => {
        card.classList.toggle("research-card--active", card === focusedCard);
      });
    };

    const scheduleFocusedCardUpdate = () => {
      if (pendingFrame) {
        return;
      }

      pendingFrame = window.requestAnimationFrame(updateFocusedCard);
    };

    cards.forEach((card) => {
      card.addEventListener("focusin", () => {
        card.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
      });
    });

    track.addEventListener("scroll", scheduleFocusedCardUpdate, { passive: true });
    window.addEventListener("resize", scheduleFocusedCardUpdate);
    window.requestAnimationFrame(updateFocusedCard);
  });
</script>

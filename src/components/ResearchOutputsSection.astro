---
import { publications } from "../data/publications";
---

<section class="section compact-section" id="publications" aria-labelledby="publications-title">
  <div class="container">
    <div class="compact-heading">
      <h2 id="publications-title">Research Outputs</h2>
      <span aria-hidden="true"></span>
    </div>

    <div class="compact-list">
      {
        publications.map((publication) => (
          <article class="compact-row">
            <div class="compact-row__date">{publication.year}</div>

            <div class="compact-row__body">
              <h3>{publication.title}</h3>
              <p class="compact-meta">{publication.venue}</p>
              <p class="compact-summary">{publication.summary}</p>
              <p class="compact-authors">{publication.authors}</p>

              <ul class="compact-links" aria-label={`${publication.title} links`}>
                {
                  publication.links.map((link) => (
                    <li>
                      <a href={link.href} target="_blank" rel="noreferrer">
                        {link.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

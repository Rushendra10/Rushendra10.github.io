---
import { projects } from "../data/projects";
---

<section class="section compact-section" id="projects" aria-labelledby="projects-title">
  <div class="container">
    <div class="compact-heading">
      <h2 id="projects-title">Projects</h2>
      <span aria-hidden="true"></span>
    </div>

    <div class="compact-list compact-list--projects">
      {
        projects.map((project) => (
          <article class="compact-row project-row">
            <div class="compact-row__title">
              <h3>{project.title}</h3>
            </div>

            <div class="compact-row__body">
              <p class="compact-summary">{project.summary}</p>

              <ul class="compact-tags" aria-label={`${project.title} tags`}>
                {project.tags.map((tag) => <li>{tag}</li>)}
              </ul>

              <details class="compact-details">
                <summary>Scope</summary>
                <ul>
                  {project.highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
              </details>

              {
                project.links && (
                  <ul class="compact-links" aria-label={`${project.title} links`}>
                    {project.links.map((link) => (
                      <li>
                        <a href={link.href} target="_blank" rel="noreferrer">
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

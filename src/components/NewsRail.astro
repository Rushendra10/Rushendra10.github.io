---
import { news } from "../data/news";

const latestNews = news.slice(0, 3);

function getShortDate(date: string) {
  const [month, year] = date.split(" ");
  return `${month.slice(0, 3)} '${year.slice(-2)}`;
}
---

<aside class="news-float" aria-labelledby="latest-news-title">
  <button class="news-float__label" type="button" data-news-open>
    <span id="latest-news-title">News</span>
  </button>

  <div class="news-float__items" aria-label="Latest updates">
    {
      latestNews.map((item) => (
        <button class="news-float__item" type="button" data-news-open>
          <span>{getShortDate(item.date)}</span>
          <strong>{item.title}</strong>
        </button>
      ))
    }
  </div>

  <dialog class="news-dialog" data-news-dialog aria-labelledby="news-dialog-title">
    <div class="news-dialog__top">
      <div>
        <p class="news-dialog__eyebrow">News archive</p>
        <h2 class="news-dialog__title" id="news-dialog-title">All Updates</h2>
      </div>
      <button class="news-dialog__close" type="button" data-news-close aria-label="Close news archive">
        Close
      </button>
    </div>

    <ul class="news-dialog__list">
      {
        news.map((item) => (
          <li class="news-dialog__item">
            <span class="news-item__date">{item.date}</span>
            {
              item.href ? (
                <a class="news-item__title" href={item.href} target="_blank" rel="noreferrer">
                  {item.title}
                </a>
              ) : (
                <span class="news-item__title">{item.title}</span>
              )
            }
            <p class="news-item__description">{item.description}</p>
          </li>
        ))
      }
    </ul>
  </dialog>
</aside>

<script>
  const newsOpenButtons = document.querySelectorAll("[data-news-open]");
  const newsDialog = document.querySelector("[data-news-dialog]");
  const newsCloseButton = document.querySelector("[data-news-close]");

  newsOpenButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (newsDialog instanceof HTMLDialogElement) {
        newsDialog.showModal();
      }
    });
  });

  newsCloseButton?.addEventListener("click", () => {
    if (newsDialog instanceof HTMLDialogElement) {
      newsDialog.close();
    }
  });

  newsDialog?.addEventListener("click", (event) => {
    if (event.target === newsDialog && newsDialog instanceof HTMLDialogElement) {
      newsDialog.close();
    }
  });
</script>

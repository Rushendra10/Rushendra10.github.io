---
import { skillGroups } from "../data/skills";

const groupMeta: Record<
  string,
  {
    description: string;
    span: "compact" | "medium" | "wide" | "full";
    tone: "blue" | "gold" | "green" | "rose" | "teal";
  }
> = {
  Languages: {
    description: "Core languages I use across modeling, backend systems, automation, and data work.",
    span: "compact",
    tone: "teal",
  },
  "LLMs / Document AI": {
    description: "Tools and methods for building useful LLM workflows over unstructured documents and multimodal inputs.",
    span: "wide",
    tone: "blue",
  },
  "ML / AI": {
    description: "Modeling, fine-tuning, computer vision, and production-minded ML workflows.",
    span: "medium",
    tone: "gold",
  },
  "Backend / APIs": {
    description: "API and service patterns for shipping AI capabilities inside real products.",
    span: "compact",
    tone: "green",
  },
  "Databases / Infrastructure": {
    description: "Storage, cloud, deployment, and developer tooling that keep systems dependable.",
    span: "full",
    tone: "rose",
  },
};

const skillMarks: Record<string, string> = {
  "Agent Orchestration": "AO",
  "API Design": "AD",
  "Async Workers": "AW",
  "Azure": "AZ",
  "Bash": "$",
  "CI/CD": "CI",
  "Computer Vision": "CV",
  "Django": "DJ",
  "Docker": "DK",
  "Document AI": "DA",
  "FastAPI": "FA",
  "Fine-tuning": "FT",
  "Git": "GIT",
  "Go": "GO",
  "Hugging Face": "HF",
  "Java": "JVM",
  "JavaScript": "JS",
  "Linux": "LX",
  "LLM Evaluation": "EV",
  "LoRA": "LoRA",
  "Microservices": "MS",
  "MLOps": "ML",
  "MongoDB": "MDB",
  "MySQL": "SQL",
  "Node.js": "NODE",
  "PostgreSQL": "PG",
  "Python": "PY",
  "PyTorch": "PT",
  "RAPIDS": "GPU",
  "Redis": "RD",
  "REST APIs": "API",
  "Scikit-Learn": "SK",
  "Structured Extraction": "{}",
  "Tool Use": "TU",
  "Transformers": "TF",
  "Vision-Language Models": "VL",
};

function getSkillMark(name: string) {
  if (skillMarks[name]) {
    return skillMarks[name];
  }

  if (name.length <= 4) {
    return name.toUpperCase();
  }

  return name
    .split(/[\s/-]+/)
    .filter(Boolean)
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();
}
---

<section class="section skills-section" id="skills" aria-labelledby="skills-title">
  <div class="container">
    <div class="section__header">
      <div>
        <p class="section__kicker">Skills</p>
        <h2 class="section__title" id="skills-title">Technical strengths</h2>
      </div>
      <p class="section__intro">
        A concise map of the tools and systems I reach for most often across applied AI,
        agentic workflows, backend engineering, and infrastructure.
      </p>
    </div>

    <div class="skills-pattern" aria-label="Grouped technical skills">
      {
        skillGroups.map((group, index) => {
          const meta = groupMeta[group.title];

          return (
            <article
              class:list={[
                "skill-card",
                `skill-card--${meta.span}`,
                `skill-card--${meta.tone}`,
              ]}
            >
              <div class="skill-card__top">
                <span class="skill-card__index">{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{group.title}</h3>
                  <p>{meta.description}</p>
                </div>
              </div>

              <ul class="skill-chip-list">
                {
                  group.skills.map((skill) => (
                    <li class="skill-chip">
                      <span class="skill-chip__mark" aria-hidden="true">
                        {getSkillMark(skill.name)}
                      </span>
                      <span>{skill.name}</span>
                    </li>
                  ))
                }
              </ul>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

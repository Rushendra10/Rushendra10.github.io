---
import ExperienceSection from "../components/ExperienceSection.astro";
import Hero from "../components/Hero.astro";
import SectionShell from "../components/SectionShell.astro";
import SkillsSection from "../components/SkillsSection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
---

<BaseLayout title={`${profile.name} | Applied AI and Machine Learning`} description={profile.summary}>
  <Hero />

  <SkillsSection />

  <ExperienceSection />

  <SectionShell
    id="publications"
    kicker="Publications"
    title="Research outputs"
    intro="Publications will emphasize venue, year, contribution area, and quick links to paper pages or PDFs without making the page feel dense."
    placeholder="Next pass: render src/data/publications.ts as clean publication rows with links, tags, and compact abstracts."
  />

  <SectionShell
    id="projects"
    kicker="Projects"
    title="Selected technical work"
    intro="Project cards will stay modular so we can replace placeholders with stronger job-search-focused case studies as you choose what to feature."
    placeholder="Next pass: add project templates from src/data/projects.ts with outcomes, stack, and links."
  />

  <SectionShell
    id="talks"
    kicker="Talks"
    title="Presentations and teaching"
    intro="Talks will remain distinct from publications so invited talks, seminars, and presentations have their own clean place."
    placeholder="Next pass: render src/data/talks.ts as compact talk entries with event, location, and links where available."
  />
</BaseLayout>
